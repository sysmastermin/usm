# ===========================================
# 프론트엔드 (Vite) - Vercel 배포 시 환경 변수
# ===========================================
# API 서버 기준 URL. 마지막 /api 는 제외한 호스트까지.
# 예: 백엔드를 https://your-api.example.com 에 둔 경우
#     VITE_API_URL=https://your-api.example.com
# 로컬 개발 시 미설정이면 http://localhost:3001 사용
# VITE_API_URL=https://your-api.example.com

# ===========================================
# 백엔드 (Express + MSSQL) - 서버 호스팅용
# README_SERVER.md 참고. Vercel에는 백엔드 미배포.
# ===========================================
# DB_SERVER=
# DB_DATABASE=
# DB_USER=
# DB_PASSWORD=
# DB_OPTIONS_TRUST_SERVER_CERTIFICATE=true
